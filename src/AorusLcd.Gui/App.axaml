<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AorusLcd.Gui.App"
             xmlns:local="using:AorusLcd.Gui"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/avalonia-logo.ico"
                      ToolTipText="AorusLcd — LCD + RGB">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show window" Click="OnTrayShow" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Exit" Click="OnTrayExit" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>