<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AorusLcd.Gui.ViewModels"
        xmlns:models="using:AorusLcd.Gui.Models"
        xmlns:conv="using:AorusLcd.Gui.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="720"
        x:Class="AorusLcd.Gui.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/aoruslcd.ico"
        Width="900" Height="740" MinWidth="720" MinHeight="600"
        Title="AorusLcd - Aorus Master LCD + RGB">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#1E1E24" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF7A18" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#B8B8C0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#15151A" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="AorusLcd" FontSize="22" FontWeight="Bold" Foreground="#FF7A18" />
                    <TextBlock Text="Open-source LCD Edge View + RGB control" Foreground="#9A9AA4" FontSize="12" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Background="#22333333" CornerRadius="4" Padding="8,3" IsVisible="{Binding ServiceRunning}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="9" Height="9" Fill="#3FB950" VerticalAlignment="Center" />
                            <TextBlock Text="Service running" Foreground="#3FB950" FontSize="12" />
                        </StackPanel>
                    </Border>
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" Width="90" Height="4" />
                    <Button Content="⟳ Refresh" Command="{Binding RefreshStatusCommand}" IsEnabled="{Binding IsNotBusy}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#15151A" Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#C8C8D0" TextWrapping="Wrap" />
        </Border>

        <TabControl Padding="20,10">
            <TabItem Header="Device" FontSize="14">
                <ScrollViewer Padding="0,12">
                    <StackPanel>
                        <!-- Device -->
                        <Border Classes="card">
                            <Grid ColumnDefinitions="*,*,*,*">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Classes="label" Text="GPU" />
                                    <TextBlock Text="{Binding GpuName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Classes="label" Text="Firmware" />
                                    <TextBlock Text="{Binding Firmware}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Classes="label" Text="Panel" />
                                    <TextBlock Text="{Binding PanelState}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Classes="label" Text="Mode" />
                                    <TextBlock Text="{Binding CurrentMode}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="h2" Text="Startup &amp; tray" />
                                <CheckBox Content="Start with Windows (launch to the tray or minimized)"
                                          IsChecked="{Binding StartWithWindows}"
                                          IsEnabled="{Binding StartupSupported}" />
                                <CheckBox Content="Show system-tray icon"
                                          IsChecked="{Binding ShowTrayIcon}" Margin="0,6,0,0" />
                                <TextBlock Classes="label" FontSize="11" TextWrapping="Wrap" Margin="24,2,0,0"
                                           Text="When the tray icon is shown, closing the window hides it to the tray. When it is off (service-only), closing the window exits the app; the background service keeps updating the dashboard either way." />
                            </StackPanel>
                        </Border>
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="h2" Text="About" />
                                <TextBlock Classes="label" TextWrapping="Wrap"
                                           Text="AorusLcd - open-source control for the Aorus Master LCD Edge View and RGB Fusion 2 lighting. It connects automatically on launch (use Refresh, top-right, to reconnect). Closing the window minimizes to the system tray; the sensor feed keeps running in the background." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="LCD Panel" FontSize="14">
                <ScrollViewer Padding="0,12">
                    <StackPanel>

                <!-- Panel power -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Panel Power" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Panel On" Command="{Binding PanelOnCommand}" IsEnabled="{Binding IsNotBusy}" />
                            <Button Content="Panel Off" Command="{Binding PanelOffCommand}" IsEnabled="{Binding IsNotBusy}" />
                            <Button Content="💾 Save to panel" Command="{Binding SaveToPanelCommand}" IsEnabled="{Binding IsNotBusy}" />
                        </StackPanel>
                        <TextBlock Classes="label" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Text="Turn the LCD on or off, or persist the current content/config to the panel's NVRAM so it survives a reboot." />
                    </StackPanel>
                </Border>

                <!-- Content selector: the panel shows exactly one of these at a time -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="What to display" />
                        <TextBlock Classes="label" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"
                                   Text="The panel shows one thing at a time - pick a content type, set it up below, and send it." />
                        <WrapPanel>
                            <RadioButton GroupName="lcdContent" Content="🖼 Image" Width="150"
                                         IsChecked="{Binding SelectedLcdContent, Mode=TwoWay, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Image}" />
                            <RadioButton GroupName="lcdContent" Content="🔤 Text" Width="150"
                                         IsChecked="{Binding SelectedLcdContent, Mode=TwoWay, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Text}" />
                            <RadioButton GroupName="lcdContent" Content="🎞 Animated GIF" Width="150"
                                         IsChecked="{Binding SelectedLcdContent, Mode=TwoWay, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Gif}" />
                            <RadioButton GroupName="lcdContent" Content="✨ Built-in Screen" Width="150"
                                         IsChecked="{Binding SelectedLcdContent, Mode=TwoWay, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=BuiltIn}" />
                            <RadioButton GroupName="lcdContent" Content="🔁 Carousel" Width="150"
                                         IsChecked="{Binding SelectedLcdContent, Mode=TwoWay, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Carousel}" />
                            <RadioButton GroupName="lcdContent" Content="📊 Sensor Dashboard" Width="150"
                                         IsChecked="{Binding SelectedLcdContent, Mode=TwoWay, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Sensors}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Live preview of the 320x170 panel content -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Panel Preview" />
                        <Border Width="320" Height="170" Background="#000000" CornerRadius="6"
                                ClipToBounds="True" HorizontalAlignment="Left">
                            <Panel>
                                <Image Source="{Binding PreviewImage}" Stretch="Uniform" IsVisible="{Binding HasPreview}" />
                                <TextBlock Text="{Binding PreviewCaption}" Foreground="#8A8A94" FontSize="12"
                                           TextWrapping="Wrap" TextAlignment="Center" Margin="16"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           IsVisible="{Binding !HasPreview}" />
                            </Panel>
                        </Border>
                        <TextBlock Classes="label" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Text="{Binding PreviewCaption}" IsVisible="{Binding HasPreview}" />
                    </StackPanel>
                </Border>

                <!-- Image -->
                <Border Classes="card" IsVisible="{Binding IsImageContent}">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="h2" Text="Custom Image" />
                        <Button Content="📂 Choose image…" Command="{Binding BrowseImageCommand}" HorizontalAlignment="Left" IsEnabled="{Binding IsNotBusy}" />
                        <TextBlock Classes="label" Text="{Binding ImagePath}" TextWrapping="Wrap" FontSize="11" />
                        <CheckBox Content="Hide sensor overlay (clean image)" IsChecked="{Binding ClearSensorsOnSend}" />
                        <CheckBox Content="Save to panel (survives reboot)" IsChecked="{Binding SaveOnSend}" />
                        <Button Content="⬆ Send to LCD" Command="{Binding SendImageCommand}"
                                Background="#FF7A18" Foreground="White" HorizontalAlignment="Left" IsEnabled="{Binding IsNotBusy}" />
                        <TextBlock Classes="label" FontSize="11"
                                   Text="Image is resized to 320×170 and sent as the panel background." />
                    </StackPanel>
                </Border>

                <!-- Built-in modes -->
                <Border Classes="card" IsVisible="{Binding IsBuiltInContent}">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Built-in Screens" />
                        <TextBlock Classes="label" FontSize="11" Margin="0,0,0,10"
                                   Text="Gigabyte's built-in animated screens and clock." />
                        <ItemsControl ItemsSource="{Binding ModePresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:ModePreset">
                                    <Button Content="{Binding Name}" Margin="0,0,10,0" Width="130"
                                            Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).SetModeCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).IsNotBusy}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Text -->
                <Border Classes="card" IsVisible="{Binding IsTextContent}">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Text" />
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Classes="label" Grid.Row="0" Grid.Column="0" Text="Message" Margin="0,0,12,8" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TextInput}" Margin="0,0,0,8" />

                            <TextBlock Classes="label" Grid.Row="1" Grid.Column="0" Text="Text / BG (RRGGBB)" Margin="0,0,12,8" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                                <TextBox Text="{Binding TextColorHex}" Width="110" />
                                <ColorPicker Color="{Binding TextColorHex, Mode=TwoWay, Converter={x:Static conv:HexColorConverter.Instance}}"
                                             IsAlphaEnabled="False" VerticalAlignment="Center" />
                                <TextBox Text="{Binding TextBgHex}" Width="110" />
                                <ColorPicker Color="{Binding TextBgHex, Mode=TwoWay, Converter={x:Static conv:HexColorConverter.Instance}}"
                                             IsAlphaEnabled="False" VerticalAlignment="Center" />
                                <TextBlock Classes="label" Text="Size" />
                                <NumericUpDown Value="{Binding TextSize}" Minimum="8" Maximum="120" Width="110" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="14">
                                <Button Content="⬆ Send text to LCD" HorizontalAlignment="Left"
                                        Command="{Binding SendTextCommand}" Background="#FF7A18" Foreground="White" IsEnabled="{Binding IsNotBusy}" />
                                <CheckBox Content="Rainbow effect" IsChecked="{Binding TextRainbowEffect}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- GIF -->
                <Border Classes="card" IsVisible="{Binding IsGifContent}">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Animated GIF" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="📂 Choose GIF…" Command="{Binding BrowseGifCommand}" IsEnabled="{Binding IsNotBusy}" />
                            <Button Content="⬆ Send GIF to LCD" Command="{Binding SendGifCommand}"
                                    Background="#FF7A18" Foreground="White" IsEnabled="{Binding IsNotBusy}" />
                        </StackPanel>
                        <TextBlock Classes="label" Text="{Binding GifPath}" TextWrapping="Wrap" FontSize="11" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Carousel -->
                <Border Classes="card" IsVisible="{Binding IsCarouselContent}">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Carousel" />
                        <TextBlock Classes="label" FontSize="11" Margin="0,0,0,10"
                                   Text="Rotate automatically through the selected screens." />
                        <WrapPanel>
                            <CheckBox Content="Faith 1" IsChecked="{Binding CarouselFaith1}" Width="130" />
                            <CheckBox Content="Faith 2" IsChecked="{Binding CarouselFaith2}" Width="130" />
                            <CheckBox Content="Faith 3" IsChecked="{Binding CarouselFaith3}" Width="130" />
                            <CheckBox Content="Custom Image" IsChecked="{Binding CarouselImage}" Width="130" />
                            <CheckBox Content="Chibi Clock" IsChecked="{Binding CarouselChibi}" Width="130" />
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,10,0,0">
                            <TextBlock Classes="label" Text="Interval (s)" />
                            <NumericUpDown Value="{Binding CarouselInterval}" Minimum="1" Maximum="255" Width="120" />
                            <Button Content="Apply carousel" Command="{Binding ApplyCarouselCommand}" IsEnabled="{Binding IsNotBusy}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Sensors -->
                <Border Classes="card" IsVisible="{Binding IsSensorContent}">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Sensor Dashboard" />
                        <TextBlock Classes="label" FontSize="11" Margin="0,0,0,10"
                                   Text="The panel's built-in overlay of live GPU widgets. Check the ones to rotate through; uncheck all for a clean panel." />
                        <WrapPanel>
                            <CheckBox Content="GPU Temp" IsChecked="{Binding ShowGpuTemp}" Width="150" />
                            <CheckBox Content="GPU Clock" IsChecked="{Binding ShowGpuClock}" Width="150" />
                            <CheckBox Content="GPU Usage" IsChecked="{Binding ShowGpuUsage}" Width="150" />
                            <CheckBox Content="Fan Speed" IsChecked="{Binding ShowFanSpeed}" Width="150" />
                            <CheckBox Content="RAM Clock" IsChecked="{Binding ShowRamClock}" Width="150" />
                            <CheckBox Content="RAM Usage" IsChecked="{Binding ShowRamUsage}" Width="150" />
                            <CheckBox Content="FPS" IsChecked="{Binding ShowFps}" Width="150" />
                            <CheckBox Content="TGP" IsChecked="{Binding ShowTgp}" Width="150" />
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,10,0,0">
                            <TextBlock Classes="label" Text="Rotation interval (s)" />
                            <NumericUpDown Value="{Binding SensorInterval}" Minimum="1" Maximum="255" Width="120" />
                            <Button Content="Apply sensors" Command="{Binding ApplySensorsCommand}" IsEnabled="{Binding IsNotBusy}" />
                            <Button Content="Sensors off" Command="{Binding SensorsOffCommand}" IsEnabled="{Binding IsNotBusy}" />
                        </StackPanel>

                        <!-- Background service: only shown here, and only once a live widget is selected -->
                        <Border Background="#15151A" CornerRadius="8" Padding="14" Margin="0,14,0,0"
                                IsVisible="{Binding ShowServiceForSensors}">
                            <StackPanel>
                                <TextBlock Text="Background service" FontWeight="SemiBold" Foreground="#FF7A18" Margin="0,0,0,6" />
                                <TextBlock Classes="label" FontSize="11" TextWrapping="Wrap"
                                           Text="Live widgets refresh about once a second (up to every few seconds for a rotating multi-widget dashboard), so they only keep updating while a small background Windows service runs. Install it once and the dashboard stays live with this app closed." />
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                    <TextBlock Classes="label" Text="Status:" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ServiceStatusText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                    <Button Content="Install service" Command="{Binding InstallServiceCommand}"
                                            IsVisible="{Binding !ServiceInstalled}" IsEnabled="{Binding IsNotBusy}" />
                                    <Button Content="Start" Command="{Binding StartServiceCommand}"
                                            IsVisible="{Binding ServiceInstalled}" IsEnabled="{Binding !ServiceRunning}" />
                                    <Button Content="Stop" Command="{Binding StopServiceCommand}"
                                            IsVisible="{Binding ServiceInstalled}" IsEnabled="{Binding ServiceRunning}" />
                                    <Button Content="Uninstall" Command="{Binding UninstallServiceCommand}"
                                            IsVisible="{Binding ServiceInstalled}" IsEnabled="{Binding IsNotBusy}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="RGB Lighting" FontSize="14" IsVisible="{Binding ShowLegacyRgb}">
                <ScrollViewer Padding="0,12">
                    <StackPanel>
                        <!-- RGB (legacy 8-byte controller: pre-Blackwell cards) -->
                        <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="RGB Lighting" />
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <TextBlock Classes="label" Grid.Row="0" Grid.Column="0" Text="Effect" Margin="0,0,12,8" />
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding RgbModes}"
                                      SelectedItem="{Binding SelectedRgbMode}" HorizontalAlignment="Left" Width="200" Margin="0,0,0,8" />

                            <TextBlock Classes="label" Grid.Row="1" Grid.Column="0" Text="Colors" Margin="0,0,12,8" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="8" Margin="0,0,0,8">
                                <Border Height="24" CornerRadius="4" Background="{Binding RgbPreviewBrush}" />
                                <ItemsControl ItemsSource="{Binding RgbColorList}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,8,4">
                                                <ColorPicker Color="{Binding Hex, Mode=TwoWay, Converter={x:Static conv:HexColorConverter.Instance}}"
                                                             IsAlphaEnabled="False" VerticalAlignment="Center" />
                                                <Button Content="✕" Padding="6,2" VerticalAlignment="Center"
                                                        Command="{Binding $parent[ItemsControl].DataContext.RemoveColorCommand}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Add color" HorizontalAlignment="Left"
                                        Command="{Binding AddColorCommand}" IsVisible="{Binding IsAnyMultiColorMode}" />
                            </StackPanel>

                            <TextBlock Classes="label" Grid.Row="2" Grid.Column="0" Text="Brightness" Margin="0,0,12,8" />
                            <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <Slider Minimum="0" Maximum="100" Value="{Binding RgbBrightness}" />
                                <TextBlock Grid.Column="1" Classes="label" Text="{Binding RgbBrightness}" Width="36" TextAlignment="Right" />
                            </Grid>

                            <TextBlock Classes="label" Grid.Row="3" Grid.Column="0" Text="Speed" Margin="0,0,12,0" />
                            <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="*,Auto">
                                <Slider Minimum="0" Maximum="5" Value="{Binding RgbSpeed}" TickFrequency="1" IsSnapToTickEnabled="True" />
                                <TextBlock Grid.Column="1" Classes="label" Text="{Binding RgbSpeed}" Width="36" TextAlignment="Right" />
                            </Grid>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                            <Button Content="Apply RGB" Command="{Binding ApplyRgbCommand}"
                                    Background="#FF7A18" Foreground="White" IsEnabled="{Binding IsNotBusy}" />
                            <Button Content="RGB off" Command="{Binding RgbOffCommand}" IsEnabled="{Binding IsNotBusy}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="RGB Lighting" FontSize="14" IsVisible="{Binding ShowBlackwellRgb}">
                <ScrollViewer Padding="0,12">
                    <StackPanel>
                        <!-- RGB (Blackwell 64-byte controller: RTX 50-series cards) -->
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="h2" Text="RGB Lighting" />
                                <TextBlock Classes="label" FontSize="11" Margin="0,0,0,10"
                                           Text="RTX 50-series (Blackwell) RGB Fusion 2 controller." />
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                    <TextBlock Classes="label" Grid.Row="0" Grid.Column="0" Text="Effect" Margin="0,0,12,8" />
                                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding RgbBlackwellModes}"
                                              SelectedItem="{Binding SelectedRgbBlackwellMode}" HorizontalAlignment="Left" Width="200" Margin="0,0,0,8" />

                                    <TextBlock Classes="label" Grid.Row="1" Grid.Column="0" Text="Colors" Margin="0,0,12,8" />
                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="8" Margin="0,0,0,8">
                                        <Border Height="24" CornerRadius="4" Background="{Binding RgbPreviewBrush}" />
                                        <ItemsControl ItemsSource="{Binding RgbColorList}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,8,4">
                                                        <ColorPicker Color="{Binding Hex, Mode=TwoWay, Converter={x:Static conv:HexColorConverter.Instance}}"
                                                                     IsAlphaEnabled="False" VerticalAlignment="Center" />
                                                        <Button Content="✕" Padding="6,2" VerticalAlignment="Center"
                                                                Command="{Binding $parent[ItemsControl].DataContext.RemoveColorCommand}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="+ Add color" HorizontalAlignment="Left"
                                                Command="{Binding AddColorCommand}" IsVisible="{Binding IsAnyMultiColorMode}" />
                                    </StackPanel>

                                    <TextBlock Classes="label" Grid.Row="2" Grid.Column="0" Text="Brightness" Margin="0,0,12,8" />
                                    <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                        <Slider Minimum="0" Maximum="100" Value="{Binding RgbBrightness}" />
                                        <TextBlock Grid.Column="1" Classes="label" Text="{Binding RgbBrightness}" Width="36" TextAlignment="Right" />
                                    </Grid>

                                    <TextBlock Classes="label" Grid.Row="3" Grid.Column="0" Text="Speed" Margin="0,0,12,0" />
                                    <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="*,Auto">
                                        <Slider Minimum="0" Maximum="5" Value="{Binding RgbSpeed}" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        <TextBlock Grid.Column="1" Classes="label" Text="{Binding RgbSpeed}" Width="36" TextAlignment="Right" />
                                    </Grid>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                                    <Button Content="Apply RGB" Command="{Binding ApplyRgbBlackwellCommand}"
                                            Background="#FF7A18" Foreground="White" IsEnabled="{Binding IsNotBusy}" />
                                    <Button Content="RGB off" Command="{Binding RgbBlackwellOffCommand}" IsEnabled="{Binding IsNotBusy}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
