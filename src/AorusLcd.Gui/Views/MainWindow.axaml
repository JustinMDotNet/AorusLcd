<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AorusLcd.Gui.ViewModels"
        xmlns:models="using:AorusLcd.Gui.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="720"
        x:Class="AorusLcd.Gui.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="900" Height="740" MinWidth="720" MinHeight="600"
        Title="AorusLcd — Aorus Master LCD + RGB">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#1E1E24" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF7A18" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#B8B8C0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#15151A" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="AorusLcd" FontSize="22" FontWeight="Bold" Foreground="#FF7A18" />
                    <TextBlock Text="Open-source LCD Edge View + RGB control" Foreground="#9A9AA4" FontSize="12" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Background="#22333333" CornerRadius="4" Padding="8,3" IsVisible="{Binding LiveFeedRunning}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="9" Height="9" Fill="#3FB950" VerticalAlignment="Center" />
                            <TextBlock Text="Live feed" Foreground="#3FB950" FontSize="12" />
                        </StackPanel>
                    </Border>
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" Width="90" Height="4" />
                    <Button Content="⟳ Refresh" Command="{Binding RefreshStatusCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#15151A" Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#C8C8D0" TextWrapping="Wrap" />
        </Border>

        <TabControl Padding="20,10">
            <TabItem Header="Device" FontSize="14">
                <ScrollViewer Padding="0,12">
                    <StackPanel>
                        <!-- Device -->
                        <Border Classes="card">
                            <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Classes="label" Text="GPU" />
                                    <TextBlock Text="{Binding GpuName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Classes="label" Text="Firmware" />
                                    <TextBlock Text="{Binding Firmware}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Classes="label" Text="Panel" />
                                    <TextBlock Text="{Binding PanelState}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Classes="label" Text="Mode" />
                                    <TextBlock Text="{Binding CurrentMode}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="10" Margin="0,14,0,0">
                                    <Button Content="Panel On" Command="{Binding PanelOnCommand}" />
                                    <Button Content="Panel Off" Command="{Binding PanelOffCommand}" />
                                    <Button Content="💾 Save to panel" Command="{Binding SaveToPanelCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="h2" Text="About" />
                                <TextBlock Classes="label" TextWrapping="Wrap"
                                           Text="AorusLcd — open-source control for the Aorus Master LCD Edge View and RGB Fusion 2 lighting. Click Refresh (top-right) to connect. Closing the window minimizes to the system tray; the sensor feed keeps running in the background." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="LCD Panel" FontSize="14">
                <ScrollViewer Padding="0,12">
                    <StackPanel>

                <!-- Image -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Custom Image" />
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="320" Height="170" Background="#000000"
                                    CornerRadius="6" ClipToBounds="True">
                                <Image Source="{Binding PreviewImage}" Stretch="UniformToFill" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="10" VerticalAlignment="Center">
                                <Button Content="📂 Choose image…" Command="{Binding BrowseImageCommand}" HorizontalAlignment="Stretch" />
                                <TextBlock Classes="label" Text="{Binding ImagePath}" TextWrapping="Wrap" FontSize="11" />
                                <CheckBox Content="Hide sensor overlay (clean image)" IsChecked="{Binding ClearSensorsOnSend}" />
                                <CheckBox Content="Save to panel (survives reboot)" IsChecked="{Binding SaveOnSend}" />
                                <Button Content="⬆ Send to LCD" Command="{Binding SendImageCommand}"
                                        Background="#FF7A18" Foreground="White" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Classes="label" FontSize="11" Margin="0,10,0,0"
                                   Text="Image is resized to 320×170 and sent as the panel background." />
                    </StackPanel>
                </Border>

                <!-- Built-in modes -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Built-in Screens" />
                        <TextBlock Classes="label" FontSize="11" Margin="0,0,0,10"
                                   Text="Gigabyte's built-in animated screens and clock." />
                        <ItemsControl ItemsSource="{Binding ModePresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:ModePreset">
                                    <Button Content="{Binding Name}" Margin="0,0,10,0" Width="130"
                                            Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).SetModeCommand}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Text -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Text" />
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Classes="label" Grid.Row="0" Grid.Column="0" Text="Message" Margin="0,0,12,8" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TextInput}" Margin="0,0,0,8" />

                            <TextBlock Classes="label" Grid.Row="1" Grid.Column="0" Text="Text / BG (RRGGBB)" Margin="0,0,12,8" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                                <TextBox Text="{Binding TextColorHex}" Width="110" />
                                <TextBox Text="{Binding TextBgHex}" Width="110" />
                                <TextBlock Classes="label" Text="Size" />
                                <NumericUpDown Value="{Binding TextSize}" Minimum="8" Maximum="120" Width="110" />
                            </StackPanel>

                            <Button Grid.Row="2" Grid.Column="1" Content="⬆ Send text to LCD" HorizontalAlignment="Left"
                                    Command="{Binding SendTextCommand}" Background="#FF7A18" Foreground="White" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- GIF -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Animated GIF" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="📂 Choose GIF…" Command="{Binding BrowseGifCommand}" />
                            <Button Content="⬆ Send GIF to LCD" Command="{Binding SendGifCommand}"
                                    Background="#FF7A18" Foreground="White" />
                        </StackPanel>
                        <TextBlock Classes="label" Text="{Binding GifPath}" TextWrapping="Wrap" FontSize="11" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Carousel -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Carousel" />
                        <TextBlock Classes="label" FontSize="11" Margin="0,0,0,10"
                                   Text="Rotate automatically through the selected screens." />
                        <WrapPanel>
                            <CheckBox Content="Faith 1" IsChecked="{Binding CarouselFaith1}" Width="130" />
                            <CheckBox Content="Faith 2" IsChecked="{Binding CarouselFaith2}" Width="130" />
                            <CheckBox Content="Faith 3" IsChecked="{Binding CarouselFaith3}" Width="130" />
                            <CheckBox Content="Custom Image" IsChecked="{Binding CarouselImage}" Width="130" />
                            <CheckBox Content="Chibi Clock" IsChecked="{Binding CarouselChibi}" Width="130" />
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,10,0,0">
                            <TextBlock Classes="label" Text="Interval (s)" />
                            <NumericUpDown Value="{Binding CarouselInterval}" Minimum="1" Maximum="255" Width="120" />
                            <Button Content="Apply carousel" Command="{Binding ApplyCarouselCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Sensors -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="Sensor Dashboard" />
                        <TextBlock Classes="label" FontSize="11" Margin="0,0,0,10"
                                   Text="The panel's built-in overlay. Check the widgets to rotate; uncheck all for a clean image." />
                        <WrapPanel>
                            <CheckBox Content="GPU Temp" IsChecked="{Binding ShowGpuTemp}" Width="150" />
                            <CheckBox Content="GPU Clock" IsChecked="{Binding ShowGpuClock}" Width="150" />
                            <CheckBox Content="GPU Usage" IsChecked="{Binding ShowGpuUsage}" Width="150" />
                            <CheckBox Content="Fan Speed" IsChecked="{Binding ShowFanSpeed}" Width="150" />
                            <CheckBox Content="RAM Clock" IsChecked="{Binding ShowRamClock}" Width="150" />
                            <CheckBox Content="RAM Usage" IsChecked="{Binding ShowRamUsage}" Width="150" />
                            <CheckBox Content="FPS" IsChecked="{Binding ShowFps}" Width="150" />
                            <CheckBox Content="TGP" IsChecked="{Binding ShowTgp}" Width="150" />
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,10,0,0">
                            <TextBlock Classes="label" Text="Rotation interval (s)" />
                            <NumericUpDown Value="{Binding SensorInterval}" Minimum="1" Maximum="255" Width="120" />
                            <Button Content="Apply sensors" Command="{Binding ApplySensorsCommand}" />
                            <Button Content="Sensors off" Command="{Binding SensorsOffCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="RGB Lighting" FontSize="14">
                <ScrollViewer Padding="0,12">
                    <StackPanel>
                        <!-- RGB -->
                        <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="h2" Text="RGB Lighting" />
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <TextBlock Classes="label" Grid.Row="0" Grid.Column="0" Text="Effect" Margin="0,0,12,8" />
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding RgbModes}"
                                      SelectedItem="{Binding SelectedRgbMode}" HorizontalAlignment="Left" Width="200" Margin="0,0,0,8" />

                            <TextBlock Classes="label" Grid.Row="1" Grid.Column="0" Text="Color (RRGGBB)" Margin="0,0,12,8" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                                <TextBox Text="{Binding RgbColorHex}" Width="120" />
                                <Border Width="36" Height="28" CornerRadius="4" Background="{Binding RgbPreviewBrush}" />
                            </StackPanel>

                            <TextBlock Classes="label" Grid.Row="2" Grid.Column="0" Text="Brightness" Margin="0,0,12,8" />
                            <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <Slider Minimum="0" Maximum="100" Value="{Binding RgbBrightness}" />
                                <TextBlock Grid.Column="1" Classes="label" Text="{Binding RgbBrightness}" Width="36" TextAlignment="Right" />
                            </Grid>

                            <TextBlock Classes="label" Grid.Row="3" Grid.Column="0" Text="Speed" Margin="0,0,12,0" />
                            <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="*,Auto">
                                <Slider Minimum="0" Maximum="5" Value="{Binding RgbSpeed}" TickFrequency="1" IsSnapToTickEnabled="True" />
                                <TextBlock Grid.Column="1" Classes="label" Text="{Binding RgbSpeed}" Width="36" TextAlignment="Right" />
                            </Grid>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                            <Button Content="Apply RGB" Command="{Binding ApplyRgbCommand}"
                                    Background="#FF7A18" Foreground="White" />
                            <Button Content="RGB off" Command="{Binding RgbOffCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
